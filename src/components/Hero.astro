---
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-24 sm:py-32 text-center">
  <div class="max-w-2xl mx-auto px-4 sm:px-6">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-[#1d1d1f] mb-3">
      {t('hero.title', lang)}
    </h1>
    <p class="text-xl sm:text-2xl font-medium text-[#0071e3] mb-6">
      {t('hero.subtitle', lang)}
    </p>
    <p class="text-lg text-[#6e6e73] leading-relaxed">
      {t('hero.tagline', lang)}
    </p>
  </div>
</section>
