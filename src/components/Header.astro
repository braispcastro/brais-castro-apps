---
import type { Lang } from '../i18n/utils';
import { t, getAlternateLang } from '../i18n/utils';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const alternateLang = getAlternateLang(lang);

// Build the alternate-language equivalent of the current path.
// currentPath looks like /en/... or /es/...
const alternatePath = currentPath.replace(`/${lang}`, `/${alternateLang}`);
---

<header class="sticky top-0 z-50 bg-white/90 dark:bg-black/90 backdrop-blur border-b border-gray-100 dark:border-[#3a3a3c]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href={`${base}/${lang}/`} class="text-base font-semibold text-[#1d1d1f] dark:text-[#f5f5f7] hover:text-[#0071e3] dark:hover:text-[#0a84ff] transition-colors">
      Brais Castro
    </a>

    <!-- Nav + Lang switcher -->
    <nav class="flex items-center gap-5 text-sm text-[#6e6e73] dark:text-[#98989d]">
      <a href={`${base}/${lang}/`} class="hover:text-[#1d1d1f] dark:hover:text-[#f5f5f7] transition-colors">{t('nav.apps', lang)}</a>
      <a href={`${base}/${lang}/privacy/`} class="hover:text-[#1d1d1f] dark:hover:text-[#f5f5f7] transition-colors">{t('nav.privacy', lang)}</a>
      <a href={`${base}/${lang}/contact/`} class="hover:text-[#1d1d1f] dark:hover:text-[#f5f5f7] transition-colors">{t('nav.contact', lang)}</a>

      <!-- Language switcher -->
      <div class="flex items-center gap-1 ml-2 text-xs font-medium border border-gray-200 dark:border-[#3a3a3c] rounded-full overflow-hidden">
        <a
          href={lang === 'en' ? '#' : `${base}${alternatePath}`}
          class={`px-2.5 py-1 transition-colors ${lang === 'en' ? 'bg-[#1d1d1f] dark:bg-[#f5f5f7] text-white dark:text-black' : 'hover:bg-gray-50 dark:hover:bg-[#2c2c2e] text-[#6e6e73] dark:text-[#98989d]'}`}
        >EN</a>
        <a
          href={lang === 'es' ? '#' : `${base}${alternatePath}`}
          class={`px-2.5 py-1 transition-colors ${lang === 'es' ? 'bg-[#1d1d1f] dark:bg-[#f5f5f7] text-white dark:text-black' : 'hover:bg-gray-50 dark:hover:bg-[#2c2c2e] text-[#6e6e73] dark:text-[#98989d]'}`}
        >ES</a>
      </div>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="ml-1 p-1.5 rounded-full text-[#6e6e73] dark:text-[#98989d] hover:bg-gray-100 dark:hover:bg-[#2c2c2e] transition-colors"
      >
        <!-- Moon: visible in light mode -->
        <svg class="dark:hidden w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
        <!-- Sun: visible in dark mode -->
        <svg class="hidden dark:block w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch (e) {}
  });

  // Follow system preference changes only when no manual override is stored
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    let stored = null;
    try { stored = localStorage.getItem('theme'); } catch (e) {}
    if (stored === null) {
      document.documentElement.classList.toggle('dark', e.matches);
    }
  });
</script>
