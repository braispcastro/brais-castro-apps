---
import type { AppData } from '../data/apps';
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/utils';
import AppCard from './AppCard.astro';

interface Props {
  apps: AppData[];
  lang: Lang;
}

const { apps, lang } = Astro.props;
---

<section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
  <h2 class="text-2xl font-bold text-[#1d1d1f] mb-8">{t('apps.section_title', lang)}</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {apps.map((app) => (
      <AppCard app={app} lang={lang} />
    ))}
  </div>
</section>
