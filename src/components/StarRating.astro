---
interface Props {
  rating: number | null;
  size?: 'sm' | 'md';
}

const { rating, size = 'md' } = Astro.props;

const starSize = size === 'sm' ? 'text-xs' : 'text-sm';

function getStars(rating: number): { full: number; empty: number } {
  const full = Math.round(rating);
  return { full, empty: 5 - full };
}

const stars = rating ? getStars(rating) : null;
---

{stars && (
  <span class={`inline-flex items-center gap-0.5 ${starSize} text-[#f5a623]`} aria-label={`${rating} out of 5 stars`}>
    {Array.from({ length: stars.full }).map(() => (
      <span>★</span>
    ))}
    {Array.from({ length: stars.empty }).map(() => (
      <span class="text-gray-200">★</span>
    ))}
  </span>
)}
