---
import { SUPPORTED_LANGS, t } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const currentPath = `/${lang}/contact/`;
const email = 'braiscastroapps@gmail.com';
---

<Layout lang={lang} title={t('meta.contact_title', lang)}>
  <Header lang={lang} currentPath={currentPath} />
  <main class="max-w-2xl mx-auto px-4 sm:px-6 py-20">
    <h1 class="text-3xl sm:text-4xl font-bold text-[#1d1d1f] dark:text-[#f5f5f7] mb-4">{t('contact.title', lang)}</h1>
    <p class="text-lg text-[#6e6e73] dark:text-[#98989d] mb-8">{t('contact.subtitle', lang)}</p>

    <div class="bg-[#f5f5f7] dark:bg-[#1c1c1e] rounded-2xl p-6 flex items-center gap-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#0071e3] dark:text-[#0a84ff] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25H4.5a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5H4.5a2.25 2.25 0 00-2.25 2.25m19.5 0-9.75 6.75L2.25 6.75" />
      </svg>
      <div>
        <p class="text-xs text-[#6e6e73] dark:text-[#98989d] mb-1">{t('contact.email_label', lang)}</p>
        <a href={`mailto:${email}`} class="text-[#0071e3] dark:text-[#0a84ff] font-medium hover:underline">{email}</a>
      </div>
    </div>

    <p class="text-sm text-[#6e6e73] dark:text-[#98989d] mt-6">{t('contact.disclaimer', lang)}</p>
  </main>
  <Footer lang={lang} />
</Layout>
