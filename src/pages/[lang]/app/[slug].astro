---
import { fetchApps } from '../../../data/apps';
import type { AppData } from '../../../data/apps';
import { SUPPORTED_LANGS, t } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/utils';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import StarRating from '../../../components/StarRating.astro';

export async function getStaticPaths() {
  const apps = await fetchApps();
  return SUPPORTED_LANGS.flatMap((lang) =>
    apps.map((app) => ({
      params: { lang, slug: app.slug },
      props: { app },
    }))
  );
}

interface Props {
  app: AppData;
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const { app } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = `/${lang}/app/${slug}/`;

const releaseYear = app.releaseDate ? new Date(app.releaseDate).getFullYear() : null;
---

<Layout lang={lang} title={`${app.name} — Brais Castro`} description={app.description.slice(0, 160)}>
  <Header lang={lang} currentPath={currentPath} />
  <main class="max-w-2xl mx-auto px-4 sm:px-6 py-12">

    <!-- Back link -->
    <a href={`${base}/${lang}/`} class="text-sm text-[#0071e3] dark:text-[#0a84ff] hover:underline inline-block mb-10">
      {t('apps.back', lang)}
    </a>

    <!-- App header -->
    <div class="flex items-start gap-5 mb-8">
      <img
        src={app.icon}
        alt={`${app.name} icon`}
        width="120"
        height="120"
        class="rounded-3xl shadow-md shrink-0"
      />
      <div class="pt-1">
        <h1 class="text-2xl sm:text-3xl font-bold text-[#1d1d1f] dark:text-[#f5f5f7] leading-tight mb-1">{app.name}</h1>
        <p class="text-sm text-[#6e6e73] dark:text-[#98989d] mb-3">{app.category}</p>

        <!-- Rating -->
        {app.rating !== null ? (
          <div class="flex items-center gap-2 text-sm text-[#6e6e73] dark:text-[#98989d] mb-3">
            <StarRating rating={app.rating} size="md" />
            <span class="font-medium text-[#1d1d1f] dark:text-[#f5f5f7]">{app.rating}</span>
            {app.ratingCount > 0 && (
              <span>({app.ratingCount.toLocaleString()} {t('apps.ratings', lang)})</span>
            )}
          </div>
        ) : (
          <p class="text-sm text-[#6e6e73] dark:text-[#98989d] mb-3">{t('apps.no_ratings', lang)}</p>
        )}

        <!-- Metadata row -->
        <div class="flex flex-wrap gap-x-5 gap-y-1 text-xs text-[#6e6e73] dark:text-[#98989d]">
          <span>{app.price === 'Free' || app.price === '0.00' ? t('apps.free', lang) : app.price}</span>
          {app.version && <span>{t('apps.version', lang)} {app.version}</span>}
          {releaseYear && <span>{t('apps.released', lang)} {releaseYear}</span>}
        </div>
      </div>
    </div>

    <!-- Download button -->
    <a
      href={app.appStoreUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 bg-[#0071e3] dark:bg-[#0a84ff] hover:bg-[#0077ed] dark:hover:bg-[#409cff] text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-colors mb-10"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
      </svg>
      {t('apps.download', lang)}
    </a>

    <!-- Description -->
    <div class="mb-10">
      <p class="text-[#3d3d3f] dark:text-[#ebebf0] leading-relaxed whitespace-pre-line">{app.description}</p>
    </div>

    <!-- Screenshots -->
    {app.screenshots.length > 0 && (
      <div class="mb-10">
        <h2 class="text-lg font-semibold text-[#1d1d1f] dark:text-[#f5f5f7] mb-4">{t('apps.screenshots', lang)}</h2>
        <div class="flex gap-3 overflow-x-auto pb-2 -mx-4 px-4 sm:mx-0 sm:px-0">
          {app.screenshots.map((url, i) => (
            <img
              src={url}
              alt={`${app.name} screenshot ${i + 1}`}
              loading="lazy"
              class="h-[400px] w-auto rounded-2xl shrink-0 shadow-sm"
            />
          ))}
        </div>
      </div>
    )}

    <!-- Privacy link -->
    <p class="text-sm text-[#6e6e73] dark:text-[#98989d]">
      <a href={`${base}/${lang}/privacy/`} class="text-[#0071e3] dark:text-[#0a84ff] hover:underline">
        {t('nav.privacy', lang)}
      </a>
    </p>
  </main>
  <Footer lang={lang} />
</Layout>
