---
// Redirect to /en/ or /es/ based on browser language.
// This is the only page that uses JS on the site.
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Brais Castro — iOS Apps</title>
    <script define:vars={{ baseUrl }}>
      const lang = navigator.language?.startsWith('es') ? 'es' : 'en';
      window.location.replace(baseUrl.replace(/\/$/, '') + '/' + lang + '/');
    </script>
    <noscript>
      <meta http-equiv="refresh" content="0; url=en/" />
    </noscript>
  </head>
  <body></body>
</html>
