---
// Renders a minimal redirect page that sends the user to the correct
// language-prefixed path based on browser language (or system default).
// Falls back to /en/ when JS is disabled.

interface Props {
  /** Path suffix after the language prefix, e.g. "contact/" or "app/mathle/" */
  suffix: string;
}

const { suffix } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <script define:vars={{ baseUrl, suffix }}>
      const lang = navigator.language?.startsWith('es') ? 'es' : 'en';
      window.location.replace(baseUrl.replace(/\/$/, '') + '/' + lang + '/' + suffix);
    </script>
    <noscript>
      <meta http-equiv="refresh" content={`0; url=${baseUrl.replace(/\/$/, '')}/en/${suffix}`} />
    </noscript>
  </head>
  <body></body>
</html>
